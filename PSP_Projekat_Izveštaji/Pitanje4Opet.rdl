  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT InvoiceLineFact.InvoiceLineKey, StockItemDimension.StockItemName, StockItemDimension.ColorName, SupplierDimension.SupplierName, SupplierDimension.PhoneNumber, SupplierDimension.FaxNumber, 
                  SupplierDimension.CityName
FROM     InvoiceLineFact INNER JOIN
                  StockItemDimension ON InvoiceLineFact.StockItemKey = StockItemDimension.StockItemKey INNER JOIN
                  SupplierDimension ON StockItemDimension.SupplierKey = SupplierDimension.SupplierKey</CommandText>
      </Query>
      <Fields>
        <Field Name="InvoiceLineKey">
          <DataField>InvoiceLineKey</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="StockItemName">
          <DataField>StockItemName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ColorName">
          <DataField>ColorName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SupplierName">
          <DataField>SupplierName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PhoneNumber">
          <DataField>PhoneNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FaxNumber">
          <DataField>FaxNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CityName">
          <DataField>CityName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!ColorName.Value</FilterExpression>
          <Operator>Like</Operator>
          <FilterValues>
            <FilterValue>*Blue*</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
  </DataSets>
