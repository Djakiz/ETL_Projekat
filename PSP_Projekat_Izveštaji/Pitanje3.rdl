  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT StockItemDimension.StockItemName, InvoiceLineFact.Quantity, TimeDimension.Season, TimeDimension.[Date], TimeDimension.[Day], TimeDimension.[Month], TimeDimension.[Year], TimeDimension.Quarter, TimeDimension.DayOfWeek, 
                  TimeDimension.DayOfWeekName, TimeDimension.DayOfYear
FROM     CustomerDimension INNER JOIN
                  InvoiceLineFact ON CustomerDimension.CustomerKey = InvoiceLineFact.CustomerKey INNER JOIN
                  StockItemDimension ON InvoiceLineFact.StockItemKey = StockItemDimension.StockItemKey INNER JOIN
                  TimeDimension ON InvoiceLineFact.TimeKey = TimeDimension.TimeKey</CommandText>
      </Query>
      <Fields>
        <Field Name="StockItemName">
          <DataField>StockItemName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Quantity">
          <DataField>Quantity</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Season">
          <DataField>Season</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Date">
          <DataField>Date</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Day">
          <DataField>Day</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Month">
          <DataField>Month</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Year">
          <DataField>Year</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Quarter">
          <DataField>Quarter</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DayOfWeek">
          <DataField>DayOfWeek</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DayOfWeekName">
          <DataField>DayOfWeekName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DayOfYear">
          <DataField>DayOfYear</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!Season.Value</FilterExpression>
          <Operator>Like</Operator>
          <FilterValues>
            <FilterValue>*Summer*</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
  </DataSets>
