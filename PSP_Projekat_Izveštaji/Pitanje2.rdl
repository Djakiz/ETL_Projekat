  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT InvoiceLineFact.InvoiceLineKey, StockItemDimension.StockItemName, StockItemDimension.[Size], SupplierDimension.SupplierName, TimeDimension.[Month], StockItemDimension.ColorName, BrandDimension.BrandName
FROM     InvoiceLineFact INNER JOIN
                  StockItemDimension ON InvoiceLineFact.StockItemKey = StockItemDimension.StockItemKey INNER JOIN
                  SupplierDimension ON StockItemDimension.SupplierKey = SupplierDimension.SupplierKey INNER JOIN
                  TimeDimension ON InvoiceLineFact.TimeKey = TimeDimension.TimeKey INNER JOIN
                  BrandDimension ON StockItemDimension.BrandKey = BrandDimension.BrandKey</CommandText>
      </Query>
      <Fields>
        <Field Name="InvoiceLineKey">
          <DataField>InvoiceLineKey</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="StockItemName">
          <DataField>StockItemName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Size">
          <DataField>Size</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SupplierName">
          <DataField>SupplierName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Month">
          <DataField>Month</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ColorName">
          <DataField>ColorName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BrandName">
          <DataField>BrandName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!Month.Value</FilterExpression>
          <Operator>Equal</Operator>
          <FilterValues>
            <FilterValue>1</FilterValue>
          </FilterValues>
        </Filter>
        <Filter>
          <FilterExpression>=Fields!Size.Value</FilterExpression>
          <Operator>Like</Operator>
          <FilterValues>
            <FilterValue>*XL*</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
  </DataSets>
