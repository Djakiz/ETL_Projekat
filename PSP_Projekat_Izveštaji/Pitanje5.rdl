  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 
    s.SupplierKey,
    s.SupplierName,
    SUM(ilf.PriceIncludingTax) AS UkupnaVrednostSaPorezom
FROM InvoiceLineFact ilf
JOIN TimeDimension td ON ilf.TimeKey = td.TimeKey
JOIN StockItemDimension sid ON ilf.StockItemKey = sid.StockItemKey
JOIN SupplierDimension s ON sid.SupplierKey = s.SupplierKey
WHERE td.Year = 2014
GROUP BY s.SupplierKey, s.SupplierName
ORDER BY UkupnaVrednostSaPorezom ASC;</CommandText>
      </Query>
      <Fields>
        <Field Name="SupplierKey">
          <DataField>SupplierKey</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="SupplierName">
          <DataField>SupplierName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UkupnaVrednostSaPorezom">
          <DataField>UkupnaVrednostSaPorezom</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Q1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT 
    s.SupplierKey,
    s.SupplierName,
    SUM(ilf.PriceIncludingTax) AS UkupnaVrednostSaPorezom,
    td.Year,
    td.Quarter
FROM InvoiceLineFact ilf
JOIN TimeDimension td ON ilf.TimeKey = td.TimeKey
JOIN StockItemDimension sid ON ilf.StockItemKey = sid.StockItemKey
JOIN SupplierDimension s ON sid.SupplierKey = s.SupplierKey
GROUP BY s.SupplierKey, s.SupplierName,td.Year,td.Quarter
ORDER BY UkupnaVrednostSaPorezom ASC;</CommandText>
      </Query>
      <Fields>
        <Field Name="SupplierKey">
          <DataField>SupplierKey</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="SupplierName">
          <DataField>SupplierName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UkupnaVrednostSaPorezom">
          <DataField>UkupnaVrednostSaPorezom</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Year">
          <DataField>Year</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Quarter">
          <DataField>Quarter</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!Year.Value</FilterExpression>
          <Operator>Equal</Operator>
          <FilterValues>
            <FilterValue DataType="Integer">2014</FilterValue>
          </FilterValues>
        </Filter>
        <Filter>
          <FilterExpression>=Fields!Quarter.Value</FilterExpression>
          <Operator>Equal</Operator>
          <FilterValues>
            <FilterValue DataType="Integer">1</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
