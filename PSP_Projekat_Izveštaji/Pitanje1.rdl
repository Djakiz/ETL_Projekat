  <DataSources>
    <DataSource Name="DataSource1">
      <DataSourceReference>PSP_WorldWideImportersDW</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>cf9e452e-5555-4fd3-886c-32815b6d748b</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DataSource1</DataSourceName>
        <CommandText>SELECT SupplierDimension.SupplierName, SupplierDimension.SupplierCategoryName,InvoiceLineFact.InvoiceLineKey, TimeDimension.[Year]
FROM     InvoiceLineFact INNER JOIN
                  StockItemDimension ON InvoiceLineFact.StockItemKey = StockItemDimension.StockItemKey INNER JOIN
                  SupplierDimension ON StockItemDimension.SupplierKey = SupplierDimension.SupplierKey INNER JOIN
                  TimeDimension ON InvoiceLineFact.TimeKey = TimeDimension.TimeKey</CommandText>
      </Query>
      <Fields>
        <Field Name="SupplierName">
          <DataField>SupplierName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="SupplierCategoryName">
          <DataField>SupplierCategoryName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="InvoiceLineKey">
          <DataField>InvoiceLineKey</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Year">
          <DataField>Year</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=Fields!Year.Value</FilterExpression>
          <Operator>Equal</Operator>
          <FilterValues>
            <FilterValue DataType="Integer">2013</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
    </DataSet>
  </DataSets>
