      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{FA273151-8EE7-4F96-99CC-C1BA423A17C7}"
          SQLTask:SqlStatementSource="IF OBJECT_ID('dbo.Seq_PackageTypeDimension', 'SO') IS NOT NULL&#xA;    DROP SEQUENCE dbo.Seq_PackageTypeDimension;&#xA;&#xA;IF OBJECT_ID('dbo.Seq_TimeDimension', 'SO') IS NOT NULL&#xA;    DROP SEQUENCE dbo.Seq_TimeDimension;&#xA;&#xA;IF OBJECT_ID('dbo.Seq_BrandDimension', 'SO') IS NOT NULL&#xA;    DROP SEQUENCE dbo.Seq_BrandDimension;&#xA;&#xA;IF OBJECT_ID('dbo.Seq_CustomerDimension', 'SO') IS NOT NULL&#xA;    DROP SEQUENCE dbo.Seq_CustomerDimension;&#xA;&#xA;IF OBJECT_ID('dbo.Seq_DeliveryMethodDimension', 'SO') IS NOT NULL&#xA;    DROP SEQUENCE dbo.Seq_DeliveryMethodDimension;&#xA;&#xA;IF OBJECT_ID('dbo.Seq_PaymentMethodDimension', 'SO') IS NOT NULL&#xA;    DROP SEQUENCE dbo.Seq_PaymentMethodDimension;&#xA;&#xA;IF OBJECT_ID('dbo.Seq_SalesPersonDimension', 'SO') IS NOT NULL&#xA;    DROP SEQUENCE dbo.Seq_SalesPersonDimension;&#xA;&#xA;IF OBJECT_ID('dbo.Seq_StockItemDimension', 'SO') IS NOT NULL&#xA;    DROP SEQUENCE dbo.Seq_StockItemDimension;&#xA;&#xA;IF OBJECT_ID('dbo.Seq_SupplierDimension', 'SO') IS NOT NULL&#xA;    DROP SEQUENCE dbo.Seq_SupplierDimension;&#xA;&#xA;IF OBJECT_ID('dbo.Seq_InvoiceLineFact', 'SO') IS NOT NULL&#xA;    DROP SEQUENCE dbo.Seq_InvoiceLineFact;&#xA;&#xA;&#xA;IF OBJECT_ID('dbo.InvoiceLineFact', 'U') IS NOT NULL&#xA;&#x9;DROP TABLE dbo.InvoiceLineFact&#xA;IF OBJECT_ID('dbo.StockItemDimension', 'U') IS NOT NULL&#xA;&#x9;DROP TABLE dbo.StockItemDimension&#xA;IF OBJECT_ID('dbo.TimeDimension', 'U') IS NOT NULL&#xA;&#x9;DROP TABLE dbo.TimeDimension&#xA;IF OBJECT_ID('dbo.SupplierDimension', 'U') IS NOT NULL&#xA;&#x9;DROP TABLE dbo.SupplierDimension&#xA;IF OBJECT_ID('dbo.DeliveryMethodDimension', 'U') IS NOT NULL&#xA;&#x9;DROP TABLE dbo.DeliveryMethodDimension&#xA;IF OBJECT_ID('dbo.CustomerDimension', 'U') IS NOT NULL&#xA;&#x9;DROP TABLE dbo.CustomerDimension&#xA;IF OBJECT_ID('dbo.SalesPersonDimension', 'U') IS NOT NULL&#xA;&#x9;DROP TABLE dbo.SalesPersonDimension&#xA;&#xA;IF OBJECT_ID('dbo.BrandDimension', 'U') IS NOT NULL&#xA;&#x9;DROP TABLE dbo.BrandDimension&#xA;IF OBJECT_ID('dbo.PaymentMethodDimension', 'U') IS NOT NULL&#xA;&#x9;DROP TABLE dbo.PaymentMethodDimension&#xA;IF OBJECT_ID('dbo.PackageTypeDimension', 'U') IS NOT NULL&#xA;&#x9;DROP TABLE dbo.PackageTypeDimension" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\INSERT"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{9400D07A-3781-400E-BB8C-BEF374ACB1E5}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="INSERT"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{FA273151-8EE7-4F96-99CC-C1BA423A17C7}"
          SQLTask:SqlStatementSource="INSERT INTO PackageTypeDimension(PackageTypeKey, PackageTypeID, PackageTypeName) &#xA;SELECT NEXT VALUE FOR Seq_PackageTypeDimension, 0, 'NEPOZNATO';&#xA;&#xA; INSERT INTO CustomerDimension(CustomerKey,CustomerID,CustomerName,CreditLimit,PhoneNumber,FaxNumber,IsStatementSent,IsOnCreditHold,StandardDiscountPercentage,CustomerCategoryName)&#xA;SELECT NEXT VALUE FOR Seq_CustomerDimension,0,'NEPOZNATO',-1,'NEPOZNATO','NEPOZNATO','NEPOZNATO','NEPOZNATO',0,'NEPOZNATO'&#xA;&#xA;INSERT INTO DeliveryMethodDimension(DeliveryMethodKey, DeliveryMethodID, DeliveryMethodName) &#xA;SELECT NEXT VALUE FOR Seq_DeliveryMethodDimension, 0, 'NEPOZNATO';&#xA;&#xA;INSERT INTO PaymentMethodDimension(PaymentMethodKey, PaymentMethodID, PaymentMethodName) &#xA;SELECT NEXT VALUE FOR Seq_PaymentMethodDimension, 0, 'NEPOZNATO';&#xA;&#xA;INSERT INTO SupplierDimension&#xA;(SupplierKey,SupplierID,SupplierName,BankAccountName,BankAccountBranch,BankAccountCode,BankAccountNumber,BankInternationalCode,PhoneNumber,FaxNumber,SupplierCategoryName,CityName,StateProvinceName,CountryName,PrimaryContactFullName,AlternateContactFullName,DeliveryMethodKey)&#xA;SELECT NEXT VALUE FOR Seq_SupplierDimension,&#xA;0,'NEPOZNATO', 'NEPOZNATO', 'NEPOZNATO', 'NEPOZNATO', 'NEPOZNATO', 'NEPOZNATO', 'NEPOZNATO','NEPOZNATO', 'NEPOZNATO', 'NEPOZNATO', 'NEPOZNATO', 'NEPOZNATO', 'NEPOZNATO', 'NEPOZNATO', 0;&#xA;&#xA;INSERT INTO BrandDimension(BrandName)  VALUES ('NEPOZNATO')&#xA;&#xA;INSERT INTO SalesPersonDimension&#xA;(SalesPersonKey, PersonID, FullName,PreferredName,PhoneNumber,FaxNumber,EmailAddress,IsSalesperson)&#xA;SELECT NEXT VALUE FOR Seq_SalesPersonDimension,&#xA;0,'NEPOZNATO','NEPOZNATO','NEPOZNATO','NEPOZNATO','NEPOZNATO',NULL&#xA;&#xA;INSERT INTO StockItemDimension&#xA;(StockItemKey,StockItemID,StockItemName,Size,ColorName,BrandKey,SupplierKey)&#xA;SELECT NEXT VALUE FOR Seq_StockItemDimension,&#xA;0,'NEPOZNATO','NEPOZNATO','NEPOZNATO',0,0&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
