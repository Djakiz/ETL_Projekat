          SQLTask:SqlStatementSource="CREATE TABLE TimeDimension (&#xA;&#x9;TimeKey INT IDENTITY(1,1) PRIMARY KEY,&#xA;&#x9;[Date] DATE NOT NULL,&#xA;&#x9;[Day] INT NOT NULL,&#xA;&#x9;[Month] NVARCHAR(20) NOT NULL,&#xA;&#x9;[Year] INT NOT NULL,&#xA;&#x9;[Quarter] INT NOT NULL,&#xA;&#x9;[DayOfWeek] INT NOT NULL,&#xA;&#x9;[DayOfWeekName] NVARCHAR(15) NOT NULL,&#xA;&#x9;[DayOfYear] INT NOT NULL,&#xA;&#x9;[Season] NVARCHAR(15) NOT NULL&#xA;&#xA;)&#xA;&#xA;CREATE TABLE [PackageTypeDimension] (&#xA;    [PackageTypeKey] int primary key,&#xA;    [PackageTypeID] int,&#xA;    [PackageTypeName] nvarchar(50)&#xA;)&#xA;&#xA;&#xA;CREATE TABLE [CustomerDimension] (&#xA;    [CustomerKey] int primary key,&#xA;    [CustomerID] int,&#xA;    [CustomerName] nvarchar(100),&#xA;    [CreditLimit] numeric(18,2),&#xA;    [PhoneNumber] nvarchar(20),&#xA;    [FaxNumber] nvarchar(20),&#xA;    [IsStatementSent] nvarchar(20),&#xA;    [IsOnCreditHold] nvarchar(20),&#xA;    [StandardDiscountPercentage] numeric(18,3),&#xA;    [CustomerCategoryName] nvarchar(50)&#xA;)&#xA;&#xA;&#xA;CREATE TABLE [DeliveryMethodDimension] (&#xA;    [DeliveryMethodKey] int primary key,&#xA;    [DeliveryMethodID] int,&#xA;    [DeliveryMethodName] nvarchar(50)&#xA;)&#xA;&#xA;&#xA;CREATE TABLE [PaymentMethodDimension] (&#xA;    [PaymentMethodKey] int  primary key,&#xA;    [PaymentMethodID] int,&#xA;    [PaymentMethodName] nvarchar(50)&#xA;)&#xA;&#xA;&#xA;CREATE TABLE [SalesPersonDimension] (&#xA;    [SalesPersonKey] int primary key,&#xA;    [PersonID] int,&#xA;    [FullName] nvarchar(50),&#xA;    [PreferredName] nvarchar(50),&#xA;    [PhoneNumber] nvarchar(20),&#xA;    [FaxNumber] nvarchar(20),&#xA;    [EmailAddress] nvarchar(256),&#xA;    [IsSalesperson] bit&#xA;)&#xA;&#xA;CREATE TABLE [BrandDimension] (&#xA;&#x9;[BrandKey] int identity(0,1) primary key,&#xA;&#x9;BrandName nvarchar(102)&#xA;)&#xA;&#xA;CREATE TABLE [SupplierDimension] (&#xA;    [SupplierKey] int primary key,&#xA;    [SupplierID] int,&#xA;    [SupplierName] nvarchar(100),&#xA;    [BankAccountName] nvarchar(50),&#xA;    [BankAccountBranch] nvarchar(50),&#xA;    [BankAccountCode] nvarchar(20),&#xA;    [BankAccountNumber] nvarchar(20),&#xA;    [BankInternationalCode] nvarchar(20),&#xA;    [PhoneNumber] nvarchar(20),&#xA;    [FaxNumber] nvarchar(20),&#xA;    [SupplierCategoryName] nvarchar(50),&#xA;    [CityName] nvarchar(50),&#xA;    [StateProvinceName] nvarchar(50),&#xA;    [CountryName] nvarchar(60),&#xA;    [PrimaryContactFullName] nvarchar(50),&#xA;    [AlternateContactFullName] nvarchar(50),&#xA;    [DeliveryMethodKey] int&#xA;)&#xA;&#xA;&#xA;CREATE TABLE [StockItemDimension] (&#xA;    [StockItemKey] int primary key,&#xA;    [StockItemID] int,&#xA;    [StockItemName] nvarchar(100),&#xA;    [Size] nvarchar(20),&#xA;    [ColorName] nvarchar(20),&#xA;    [BrandKey] int,&#xA;    [SupplierKey] int&#xA;)&#xA;&#xA;&#xA;&#xA;CREATE TABLE [InvoiceLineFact] (&#xA;    [InvoiceLineKey] int identity(1,1) primary key,&#xA;    [InvoiceLineID] int,&#xA;    [InvoiceID] int,&#xA;    [Quantity] int,&#xA;    [UnitPrice] numeric(18,2),&#xA;    [TaxRate] numeric(18,3),&#xA;    [LineProfit] numeric(18,2),&#xA;    [Description] nvarchar(100),&#xA;    [TaxAmount] numeric(38,2),&#xA;    [PriceExcludingTax] numeric(29,2),&#xA;    [PriceIncludingTax] numeric(38,2),&#xA;    [CustomerKey] int,&#xA;    [PackageTypeKey] int,&#xA;    [StockItemKey] int,&#xA;    [TimeKey] int,&#xA;    [SalesPersonKey] int&#xA;&#x9;&#xA;)&#xA;&#xA;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
